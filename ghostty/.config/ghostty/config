# font
font-size = 18
# font-family = JetBrainsMonoNL Nerd Font
font-family = CaskaydiaMono Nerd Font 

#opacity
background-opacity = 0.70
# background-blur-radius = 40

# cursor
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor
